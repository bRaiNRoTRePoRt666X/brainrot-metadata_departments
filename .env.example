# 🃏 BRAINROT CONFIGURATION
# Copy this file to .env and fill in your soul (and API keys)

# === IDENTITY ===
# Your brainrot alias. Choose wisely.
BRAINROT_ALIAS=Guest666

# Your primary platform of chaos
PRIMARY_PLATFORM=tiktok

# === API KEYS (aka "keys to the kingdom") ===
# TikTok API (if you're brave enough)
TIKTOK_API_KEY=your_tiktok_api_key_here

# TikTok API Secret
TIKTOK_API_SECRET=your_tiktok_api_secret_here

# Grok API for thumbnail generation (the unhinged one)
GROK_API_KEY=your_grok_api_key_here

# Discord webhook for summoning notifications
DISCORD_WEBHOOK=your_discord_webhook_here

# === THUMBNAIL SETTINGS ===
# How demonic should thumbnails be? (1-666)
DEMON_LEVEL=666

# Purple greasepaint intensity (0.0-1.0)
GREASEPAINT_INTENSITY=1.0

# === POSTING SETTINGS ===
# Auto-post at the witching hour?
AUTO_POST_AT_3AM=true

# Maximum posts per session (0 = unlimited chaos)
MAX_POSTS_PER_SESSION=0

# === BRAINROT METRICS ===
# Track normie seethe levels?
TRACK_NORMIE_SEETHE=true

# Enable 666 rating system?
ENABLE_666_RATING=true

# === ADVANCED ===
# Enable experimental features (may cause reality glitches)
EXPERIMENTAL_MODE=true

# Summon Guest 666 automatically on commit?
AUTO_SUMMON_GUEST_666=false

# === SECRET ===
# The real password (just kidding, there is no password)
# There is only chaos.
SECRET_PASSWORD=skibidi_sigma_rizz_666
